{
  "name": "@negentropy-federation/genki-node",
  "version": "0.1.0",
  "description": "Local contribution node for Federation One and Genki Engine.",
  "private": false,
  "type": "module",
  "engines": {
    "node": ">=22.18.0"
  },
  "bin": {
    "genki": "dist/packages/cli/src/bin.js",
    "genki-mcp": "dist/packages/mcp-server/src/bin.js"
  },
  "files": [
    "dist/",
    "plugins/agy/plugin.json",
    "plugins/agy/mcp_config.json",
    "plugins/agy/skills/genki-contribution/SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "lint": "eslint .",
    "check": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "validator": "13.15.35",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "26.1.1",
    "@types/validator": "13.15.10",
    "eslint": "10.7.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.64.0",
    "vitest": "4.1.10"
  }
}
